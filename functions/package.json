{
  "name": "zenith-itr-functions",
  "description": "Firebase Cloud Functions for Zenith ITR (Quicko API proxy, verify token)",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.3.2",
    "form-data": "^4.0.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "private": true
}
