# Phase 1: JWT verification – URL of your deployed verifyToken function
# e.g. https://us-central1-YOUR_PROJECT.cloudfunctions.net/verifyToken
# If unset, app falls back to client-side decode (dev/demo only; no signature verification).
VITE_FIREBASE_VERIFY_TOKEN_URL=

# Quicko API – call your Firebase function URL (after deploy)
# e.g. https://us-central1-YOUR_PROJECT.cloudfunctions.net/quickoApi
VITE_FIREBASE_QUICKO_FUNCTION_URL=

# Optional: use Functions emulator in dev
# VITE_FIREBASE_EMULATOR=true

# --- Server-only (Firebase Functions config, never in frontend .env) ---
# ITR_JWT_SECRET: shared secret used by ZenithBooks to sign the redirect JWT.
# Set via: firebase functions:config:set itr.jwt_secret="YOUR_SECRET"
# Or in Firebase Console: Functions → Environment variables
